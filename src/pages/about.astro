---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Renat Elubaev"
  description="Learn about Renat Elubaev, a practicing visual artist based in Astana, Kazakhstan. Member of the Union of Artists of Kazakhstan, Grand Prix laureate, and international competition organizer."
>
  <!-- PAGE HEADER -->
  <section class="page-header" id="about-header">
    <div class="container">
      <span class="page-header__eyebrow">About</span>
      <h1 class="page-header__title">About Renat Elubaev</h1>
      <p class="page-header__desc">A practicing visual artist and organizer of the International Visual Arts Competition.</p>
    </div>
  </section>

  <!-- BIO SECTION -->
  <section class="section--sm" id="about-bio">
    <div class="container">
      <div class="about-grid">
        <!-- Photo placeholder -->
        <div class="about-photo animate-fade-in-up">
          <div class="about-photo__placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            <span>Photo of Renat Elubaev</span>
          </div>
        </div>

        <!-- Bio text -->
        <div class="about-text animate-fade-in-up delay-2">
          <p class="about-text__lead">
            Renat Elubaev (Ренат Елубаев) is a practicing visual artist based in Astana, Kazakhstan. He is a member
            of the Union of Artists of the Republic of Kazakhstan and has participated in international
            artistic projects across multiple countries.
          </p>
          <p>
            His work spans painting, digital art, and visual composition. He has participated
            in international artistic projects across Kazakhstan, Russia, Belarus, and the United States.
          </p>
          <p>
            Since 2022, Renat Elubaev has organized the International Visual Arts Competition
            bearing his name, dedicated to supporting the development of contemporary visual art
            among young and emerging artists in Kazakhstan and the CIS region.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AWARDS -->
  <section class="section awards-section" id="about-awards">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Recognition</span>
        <h2>Awards & Achievements</h2>
        <hr class="divider divider--center" />
      </div>

      <div class="awards-grid">
        <div class="award-card animate-fade-in-up">
          <div class="award-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="7"></circle>
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
            </svg>
          </div>
          <h3 class="award-card__title">Grand Prix Laureate</h3>
          <p class="award-card__desc">International Art Olympiad, Republic of Belarus</p>
        </div>

        <div class="award-card animate-fade-in-up delay-1">
          <div class="award-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          </div>
          <h3 class="award-card__title">Gold Medal Recipient</h3>
          <p class="award-card__desc">International Art Exhibition, United States</p>
        </div>

        <div class="award-card animate-fade-in-up delay-2">
          <div class="award-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
          </div>
          <h3 class="award-card__title">Record Holder</h3>
          <p class="award-card__desc">KINES Register of Kazakhstan in the field of fine arts</p>
        </div>

        <div class="award-card animate-fade-in-up delay-3">
          <div class="award-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 class="award-card__title">Member</h3>
          <p class="award-card__desc">Union of Artists of the Republic of Kazakhstan</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT INFO -->
  <section class="section--sm" id="about-contact">
    <div class="container">
      <div class="about-contact-card">
        <h3>Get in Touch</h3>
        <div class="about-contact-card__items">
          <div class="about-contact-card__item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Astana, Republic of Kazakhstan</span>
          </div>
          <div class="about-contact-card__item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <a href="tel:+77476731282">+7 (747) 673-12-82</a>
          </div>
          <div class="about-contact-card__item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <a href="mailto:elubaev_rk@mail.ru">elubaev_rk@mail.ru</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== PAGE HEADER ===== */
  .page-header {
    padding: var(--section-spacing-sm) 0;
    text-align: center;
    background: linear-gradient(to bottom, var(--color-accent-light), var(--color-bg));
  }

  .page-header__eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .page-header__title {
    margin-bottom: 0.75rem;
  }

  .page-header__desc {
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  /* ===== ABOUT GRID ===== */
  .about-grid {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-photo__placeholder {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: var(--border-radius-lg);
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-border-light));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .about-photo__placeholder svg {
    width: 56px;
    height: 56px;
    opacity: 0.35;
  }

  .about-photo__placeholder span {
    font-size: 0.85rem;
    opacity: 0.45;
    font-style: italic;
  }

  .about-text__lead {
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.8;
  }

  /* ===== SECTION EYEBROW ===== */
  .section-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  /* ===== AWARDS ===== */
  .awards-section {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
  }

  .awards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .award-card {
    background: var(--color-bg);
    border-radius: var(--border-radius-lg);
    padding: 2rem 1.5rem;
    text-align: center;
    border: 1px solid var(--color-border-light);
    transition: all var(--transition-base);
  }

  .award-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .award-card__icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .award-card__title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    font-family: var(--font-body);
  }

  .award-card__desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ===== CONTACT CARD ===== */
  .about-contact-card {
    background: var(--color-surface);
    border-radius: var(--border-radius-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .about-contact-card h3 {
    margin-bottom: 1.5rem;
  }

  .about-contact-card__items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-contact-card__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .about-contact-card__item svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .about-contact-card__item a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .about-contact-card__item a:hover {
    color: var(--color-accent);
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-photo__placeholder {
      max-width: 280px;
      margin: 0 auto;
    }

    .awards-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .awards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
