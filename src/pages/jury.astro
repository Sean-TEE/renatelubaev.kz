---
import BaseLayout from '../layouts/BaseLayout.astro';
import JuryCard from '../components/JuryCard.astro';
import juryData from '../data/jury.json';
---

<BaseLayout
  title="Jury Panel 2026 — International Visual Arts Competition"
  description="Meet the professional jury panel of the 2026 International Visual Arts Competition named after Artist Renat Elubaev."
>
  <section class="page-header" id="jury-header">
    <div class="container">
      <span class="page-header__eyebrow">Jury</span>
      <h1 class="page-header__title">Jury Panel — 2026</h1>
      <p class="page-header__desc">Professional jury composed of recognized experts in the visual arts.</p>
    </div>
  </section>

  <section class="section" id="jury-grid">
    <div class="container">
      <div class="jury-grid">
        {juryData.map((member: any, i: number) => (
          <div class={`animate-fade-in-up delay-${i + 1}`}>
            <JuryCard
              name={member.name}
              role={member.role}
              title={member.title}
              achievements={member.achievements}
              location={member.location}
              image={member.image}
              bio={member.bio}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section--sm" id="jury-note">
    <div class="container container--narrow">
      <div class="jury-note">
        <h3>How Jury Members Are Selected</h3>
        <p>The jury is formed by invitation only, based on professional achievements and recognized expertise. Jury members are selected by the competition organizer and appointed by official order.</p>
        <a href="/competition" class="btn btn--outline mt-3">View Competition Details</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--section-spacing-sm) 0;
    text-align: center;
    background: linear-gradient(to bottom, var(--color-accent-light), var(--color-bg));
  }
  .page-header__eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .page-header__title { margin-bottom: 0.75rem; }
  .page-header__desc {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }
  .jury-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .jury-note {
    background: var(--color-surface);
    border-radius: var(--border-radius-lg);
    padding: 2.5rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
  }
  .jury-note h3 { margin-bottom: 1rem; }
  .jury-note p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }
  @media (max-width: 992px) {
    .jury-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .jury-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  }
</style>
