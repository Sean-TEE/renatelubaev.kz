---
import { useTranslations } from '../../i18n/ui';

const { lang } = Astro.props || { lang: 'ru' };
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entryId = lang === 'ru' ? 'about' : `${lang}/about`;
let aboutEntry = await getEntry('pages', entryId);
if (!aboutEntry) {
  aboutEntry = await getEntry('pages', 'about');
}
if (!aboutEntry) return Astro.redirect('/404');
const { bioLead, bioText1, bioText2, profileImage, eventPhotos } = aboutEntry.data;

const t = useTranslations(lang);
---

<BaseLayout lang={lang}
  title={t('seo.about.title')}
  description={t('seo.about.desc')}
>
  <section class="page-header" id="about-header">
    <div class="container">
      <span class="page-header__eyebrow">Biography</span>
      <h1 class="page-header__title">About Renat Elubaev</h1>
    </div>
  </section>

  <section class="section about-content" id="about-content">
    <div class="container about-container">
      <div class="about-grid">
        <!-- Photo column -->
        <div class="about-photo-wrapper animate-fade-in-up">
          <div class="about-photo-frame">
          {profileImage ? (
            <img src={profileImage} alt="Renat Elubaev" class="about-img" loading="eager" />
          ) : (
            <div class="about-photo__placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              <span>Photo of Renat Elubaev</span>
            </div>
          )}
          </div>
        </div>

        <!-- Bio text -->
        <div class="about-text animate-fade-in-up delay-2">
          <p class="about-text__lead">
            {bioLead}
          </p>
          <p>
            {bioText1}
          </p>
          <p>
            {bioText2}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- AWARDS -->
  <section class="section awards-section" id="about-awards">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Recognition</span>
        <h2>Awards & Achievements</h2>
        <hr class="divider divider--center" />
      </div>

      <div class="awards-grid">
        <div class="award-card animate-fade-in-up">
          <div class="award-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="7"></circle>
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
            </svg>
          </div>
          <h3 class="award-card__title">Grand Prix Laureate</h3>
          <p class="award-card__desc">International Art Olympiad, Republic of Belarus</p>
        </div>

        <div class="award-card animate-fade-in-up delay-1">
          <div class="award-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          </div>
          <h3 class="award-card__title">Gold Medal Recipient</h3>
          <p class="award-card__desc">International Art Exhibition, United States</p>
        </div>

        <div class="award-card animate-fade-in-up delay-2">
          <div class="award-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
          </div>
          <h3 class="award-card__title">Record Holder</h3>
          <p class="award-card__desc">KINES Register of Kazakhstan in the field of fine arts</p>
        </div>

        <div class="award-card animate-fade-in-up delay-3">
          <div class="award-card__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 class="award-card__title">Member</h3>
          <p class="award-card__desc">Union of Artists of the Republic of Kazakhstan</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EVENT PHOTOS -->
  {eventPhotos && eventPhotos.length > 0 && (
    <section class="section about-gallery" id="about-gallery">
      <div class="container">
        <div class="section-header text-center" style="margin-bottom: 3rem;">
          <span class="section-eyebrow">Life & Exhibitions</span>
          <h2 style="margin-bottom: 1rem;">Photo Gallery</h2>
          <hr class="divider divider--center" />
        </div>
        
        <div class="masonry-grid" id="about-masonry">
          {eventPhotos.map((photo, index) => (
            <div class="masonry-item animate-fade-in-up" style={`animation-delay: ${0.1 * (index % 5)}s`} data-img={photo.src}>
              <div class="masonry-item__inner">
                <img src={photo.src} alt={`Event photo ${index + 1}`} class="masonry-item__image" loading="lazy" />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Lightbox Modal for About -->
    <dialog id="about-lightbox-modal" class="lightbox">
      <div class="lightbox__backdrop" id="about-lightbox-backdrop"></div>
      <div class="lightbox__container">
        <button class="lightbox__close" id="about-lightbox-close" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <div class="lightbox__content">
          <div class="lightbox__image-wrapper">
            <img id="about-lightbox-img" src="" alt="Full View" />
          </div>
        </div>
      </div>
    </dialog>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const masonryItems = document.querySelectorAll('#about-masonry .masonry-item') as NodeListOf<HTMLElement>;
        if (masonryItems.length === 0) return;
        
        const dialog = document.getElementById('about-lightbox-modal') as HTMLDialogElement;
        const img = document.getElementById('about-lightbox-img') as HTMLImageElement;
        const closeBtn = document.getElementById('about-lightbox-close');
        const backdrop = document.getElementById('about-lightbox-backdrop');

        masonryItems.forEach(item => {
          item.addEventListener('click', () => {
            img.src = item.dataset.img || '';
            dialog.showModal();
            document.body.style.overflow = 'hidden';
          });
        });

        const closeLightbox = () => {
          dialog.close();
          document.body.style.overflow = '';
        };

        closeBtn?.addEventListener('click', closeLightbox);
        backdrop?.addEventListener('click', closeLightbox);
        dialog?.addEventListener('close', () => document.body.style.overflow = '');
      });
    </script>
  )}

  <!-- CONTACT INFO -->
  <section class="section--sm" id="about-contact">
    <div class="container">
      <div class="about-contact-card">
        <h3>Get in Touch</h3>
        <div class="about-contact-card__items">
          <div class="about-contact-card__item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Astana, Republic of Kazakhstan</span>
          </div>
          <div class="about-contact-card__item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <a href="tel:+77476731282">+7 (747) 673-12-82</a>
          </div>
          <div class="about-contact-card__item">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <a href="mailto:renatelubaevkz@gmail.com">renatelubaevkz@gmail.com</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== PAGE HEADER ===== */
  .page-header {
    padding: var(--section-spacing-sm) 0;
    text-align: center;
    background: linear-gradient(to bottom, var(--color-accent-light), var(--color-bg));
  }

  .page-header__eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .page-header__title {
    margin-bottom: 0.75rem;
  }

  .page-header__desc {
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  /* ===== ABOUT GRID ===== */
  .about-grid {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .about-photo__placeholder {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: var(--border-radius-lg);
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-border-light));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .about-photo__placeholder svg {
    width: 56px;
    height: 56px;
    opacity: 0.35;
  }

  .about-photo__placeholder span {
    font-size: 0.85rem;
    opacity: 0.45;
    font-style: italic;
  }

  .about-text__lead {
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.8;
  }

  /* ===== SECTION EYEBROW ===== */
  .section-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  /* ===== AWARDS ===== */
  .awards-section {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
  }

  .awards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .award-card {
    background: var(--color-bg);
    border-radius: var(--border-radius-lg);
    padding: 2rem 1.5rem;
    text-align: center;
    border: 1px solid var(--color-border-light);
    transition: all var(--transition-base);
  }

  .award-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .award-card__icon {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .award-card__title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    font-family: var(--font-body);
  }

  .award-card__desc {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* ===== CONTACT CARD ===== */
  .about-contact-card {
    background: var(--color-surface);
    border-radius: var(--border-radius-lg);
    padding: 2.5rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .about-contact-card h3 {
    margin-bottom: 1.5rem;
  }

  .about-contact-card__items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .about-contact-card__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .about-contact-card__item svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .about-contact-card__item a {
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }

  .about-contact-card__item a:hover {
    color: var(--color-accent);
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-photo__placeholder {
      max-width: 280px;
      margin: 0 auto;
    }

    .awards-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .awards-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ===== MASONRY GALLERY ===== */
  .masonry-grid {
    column-count: 3;
    column-gap: 1.5rem;
  }

  .masonry-item {
    break-inside: avoid;
    margin-bottom: 1.5rem;
    border-radius: var(--border-radius);
    overflow: hidden;
    cursor: pointer;
    background-color: var(--color-surface);
  }

  .masonry-item__inner {
    position: relative;
    width: 100%;
    display: block;
    line-height: 0;
  }

  .masonry-item__image {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    border-radius: var(--border-radius);
    transition: transform var(--transition-base), filter var(--transition-base);
  }

  .masonry-item:hover .masonry-item__image {
    transform: scale(1.02);
    filter: brightness(0.9);
  }

  @media (max-width: 992px) {
    .masonry-grid { column-count: 2; }
  }
  @media (max-width: 576px) {
    .masonry-grid { column-count: 1; }
  }

  /* Lightbox */
  .lightbox {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 100vw;
    max-height: 100vh;
    width: 100%;
    height: 100%;
  }

  .lightbox::backdrop {
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(5px);
  }

  .lightbox__backdrop {
    position: fixed; inset: 0; z-index: -1;
  }

  .lightbox__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    position: relative;
    padding: 2rem;
  }

  .lightbox__close {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    background: rgba(0, 0, 0, 0.5);
    border: none; color: white;
    width: 44px; height: 44px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; z-index: 10;
  }

  .lightbox__close:hover { background: var(--color-accent); }

  .lightbox__content {
    display: flex; flex-direction: column; align-items: center;
    max-width: 1200px; max-height: 90vh;
  }

  .lightbox__image-wrapper {
    flex: 1; min-height: 0;
    display: flex; justify-content: center; align-items: center;
  }

  .lightbox__image-wrapper img {
    max-height: 85vh; max-width: 100%;
    object-fit: contain; border-radius: var(--border-radius);
    box-shadow: var(--shadow-lg);
  }
</style>
