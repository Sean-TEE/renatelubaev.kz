---
import { useTranslations } from '../../i18n/ui';

const { lang } = Astro.props || { lang: 'ru' };
import BaseLayout from '../../layouts/BaseLayout.astro';
import JuryCard from '../JuryCard.astro';
import { getCollection } from 'astro:content';

let juryCollection = await getCollection('jury', ({ id }) => lang === 'ru' ? !id.includes('/') : id.startsWith(`${lang}/`));
if (!juryCollection || juryCollection.length === 0) {
  juryCollection = await getCollection('jury', ({ id }) => !id.includes('/'));
}
const juryData = juryCollection
  .map(entry => entry.data)
  .sort((a, b) => (a.order || 99) - (b.order || 99));

const t = useTranslations(lang);
---

<BaseLayout lang={lang}
  title={t('seo.jury.title')}
  description={t('seo.jury.desc')}
>
  <section class="page-header" id="jury-header">
    <div class="container">
      <span class="page-header__eyebrow">{t("jury.header.eyebrow")}</span>
      <h1 class="page-header__title">{t("jury.header.title")}</h1>
      <p class="page-header__desc">{t("jury.header.desc")}</p>
    </div>
  </section>

  <section class="section" id="jury-grid">
    <div class="container">
      <div class="jury-grid">
        {juryData.map((member: any, i: number) => (
          <div class={`animate-fade-in-up delay-${i + 1}`}>
            <JuryCard
              name={member.name}
              role={member.role}
              title={member.title}
              achievements={member.achievements}
              location={member.location}
              image={member.image}
              bio={member.bio}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section--sm" id="jury-note">
    <div class="container container--narrow">
      <div class="jury-note">
        <h3>{t("jury.note.title")}</h3>
        <p>{t("jury.note.desc")}</p>
        <a href="/competition" class="btn btn--outline mt-3">{t("jury.note.btn")}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: var(--section-spacing-sm) 0;
    text-align: center;
    background: linear-gradient(to bottom, var(--color-accent-light), var(--color-bg));
  }
  .page-header__eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }
  .page-header__title { margin-bottom: 0.75rem; }
  .page-header__desc {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }
  .jury-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    align-items: start;
  }
  .jury-note {
    background: var(--color-surface);
    border-radius: var(--border-radius-lg);
    padding: 2.5rem;
    text-align: center;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
  }
  .jury-note h3 { margin-bottom: 1rem; }
  .jury-note p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }
  @media (max-width: 992px) {
    .jury-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .jury-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
  }
</style>
