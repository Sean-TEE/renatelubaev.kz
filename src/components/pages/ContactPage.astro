---
import { useTranslations } from '../../i18n/ui';

import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../ContactForm.astro';

const { lang = 'ru' } = Astro.props;

const t = useTranslations(lang);
---

<BaseLayout lang={lang}
  title={t('seo.contact.title')}
  description={t('seo.contact.desc')}
>
  <section class="page-header" id="contact-header">
    <div class="container">
      <span class="page-header__eyebrow">{t("contact.header.eyebrow")}</span>
      <h1 class="page-header__title">{t("contact.header.title")}</h1>
      <p class="page-header__desc">{t("contact.header.desc")}</p>
    </div>
  </section>

  <section class="section--sm" id="contact-content">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Info -->
        <div class="contact-info animate-fade-in-up">
          <h2>{t("contact.info.title")}</h2>
          <hr class="divider" />
          <p class="contact-info__name">Renat Elubaev</p>
          <p class="contact-info__role">{t("contact.info.role")}</p>

          <div class="contact-info__items">
            <div class="contact-info__item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <div>
                <span class="contact-info__label">{t("contact.info.addr")}</span>
                <span class="contact-info__value">Astana, Republic of Kazakhstan</span>
              </div>
            </div>
            <div class="contact-info__item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              <div>
                <span class="contact-info__label">{t("contact.info.phone")}</span>
                <a href="tel:+77476731282" class="contact-info__value">+7 (747) 673-12-82</a>
              </div>
            </div>
            <div class="contact-info__item">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              <div>
                <span class="contact-info__label">{t("contact.info.email")}</span>
                <a href="mailto:renatelubaevkz@gmail.com" class="contact-info__value">renatelubaevkz@gmail.com</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="animate-fade-in-up delay-2">
          <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>


</BaseLayout>

<style>
  .page-header {
    padding: var(--section-spacing-sm) 0;
    text-align: center;
    background: linear-gradient(to bottom, var(--color-accent-light), var(--color-bg));
  }
  .page-header__eyebrow {
    display: inline-block; font-size: 0.72rem; font-weight: 600;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--color-accent); margin-bottom: 0.75rem;
  }
  .page-header__title { margin-bottom: 0.75rem; }
  .page-header__desc {
    font-size: 1.05rem; color: var(--color-text-muted);
    max-width: 600px; margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-info h2 { margin-bottom: 0.5rem; }
  .contact-info__name {
    font-size: 1.1rem; font-weight: 600;
    color: var(--color-text); margin-bottom: 0.25rem;
  }
  .contact-info__role {
    font-size: 0.9rem; color: var(--color-text-muted);
    margin-bottom: 2rem; line-height: 1.5;
  }

  .contact-info__items {
    display: flex; flex-direction: column; gap: 1.25rem;
  }
  .contact-info__item {
    display: flex; align-items: flex-start; gap: 1rem;
  }
  .contact-info__item svg {
    color: var(--color-accent); flex-shrink: 0; margin-top: 2px;
  }
  .contact-info__item div {
    display: flex; flex-direction: column; gap: 0.15rem;
  }
  .contact-info__label {
    font-size: 0.75rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }
  .contact-info__value {
    font-size: 0.95rem; color: var(--color-text-secondary);
  }
  a.contact-info__value:hover { color: var(--color-accent); }



  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
