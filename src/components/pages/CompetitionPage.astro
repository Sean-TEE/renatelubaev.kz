---
import { useTranslations } from '../../i18n/ui';

const { lang } = Astro.props || { lang: 'ru' };
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const compEntry = await getEntry('pages', 'competition');
const { status, introText, currentEditionInfo, statsEvaluated, statsFormat } = compEntry.data;
const statusLabel = status === 'closed' ? 'Applications Closed' : 'Applications Open';
---

<BaseLayout lang={lang}
  title={t('seo.competition.title')}
  description={t('seo.competition.desc')}
>
  <!-- PAGE HEADER -->
  <section class="page-header" id="competition-header">
    <div class="container">
      <span class="page-header__eyebrow">Competition</span>
      <h1 class="page-header__title">International Visual Arts Competition</h1>
      <p class="page-header__subtitle">Named after Artist Renat Elubaev</p>
      <div class="page-header__badge">
        <span class={`badge badge--${status}`}>{statusLabel}</span>
      </div>
    </div>
  </section>

  <!-- ABOUT COMPETITION -->
  <section class="section--sm" id="competition-about">
    <div class="container container--narrow">
      <p class="comp-intro">
        {introText}
      </p>
    </div>
  </section>

  <!-- 2026 RESULTS -->
  <section class="section results-section" id="competition-results">
    <div class="container">
      <div class="section-header">
        <span class="section-eyebrow">Latest Edition</span>
        <h2>2026 Competition — Results</h2>
        <hr class="divider divider--center" />
        <p>{currentEditionInfo}</p>
      </div>

      <div class="results-stats">
        <div class="result-stat">
          <span class="result-stat__number">{statsEvaluated}</span>
          <span class="result-stat__label">Works Admitted & Evaluated</span>
        </div>
        <div class="result-stat">
          <span class="result-stat__number">4</span>
          <span class="result-stat__label">Nominations</span>
        </div>
        <div class="result-stat">
          <span class="result-stat__number">{statsFormat}</span>
          <span class="result-stat__label">Format</span>
        </div>
      </div>

      <!-- NOMINATIONS -->
      <div class="nominations" id="nominations">
        <h3 class="nominations__title">Nominations</h3>
        <div class="nominations__grid">
          <div class="nomination-card">
            <div class="nomination-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
              </svg>
            </div>
            <span class="nomination-card__name">Painting</span>
          </div>
          <div class="nomination-card">
            <div class="nomination-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                <line x1="8" y1="21" x2="16" y2="21"></line>
                <line x1="12" y1="17" x2="12" y2="21"></line>
              </svg>
            </div>
            <span class="nomination-card__name">Digital Art</span>
          </div>
          <div class="nomination-card">
            <div class="nomination-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
                <circle cx="12" cy="13" r="4"></circle>
              </svg>
            </div>
            <span class="nomination-card__name">Photography</span>
          </div>
          <div class="nomination-card">
            <div class="nomination-card__icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
              </svg>
            </div>
            <span class="nomination-card__name">Visual Composition</span>
          </div>
        </div>
      </div>

      <!-- TIMELINE -->
      <div class="timeline" id="competition-timeline">
        <h3 class="timeline__title">Competition Timeline</h3>
        <div class="timeline__items">
          <div class="timeline__item timeline__item--completed">
            <div class="timeline__marker"></div>
            <div class="timeline__content">
              <span class="timeline__date">Until March 7, 2026</span>
              <span class="timeline__label">Applications Accepted</span>
            </div>
          </div>
          <div class="timeline__item timeline__item--completed">
            <div class="timeline__marker"></div>
            <div class="timeline__content">
              <span class="timeline__date">March 9, 2026</span>
              <span class="timeline__label">Jury Evaluation</span>
            </div>
          </div>
          <div class="timeline__item timeline__item--completed">
            <div class="timeline__marker"></div>
            <div class="timeline__content">
              <span class="timeline__date">March 20, 2026</span>
              <span class="timeline__label">Results Announced</span>
            </div>
          </div>
        </div>
      </div>

      <div class="results-note">
        <p>
          Competition results were determined collegially by the jury on the basis of artistic
          originality, compositional approach, technical execution, and creative concept. Winners
          received official diplomas in electronic format.
        </p>
      </div>
    </div>
  </section>

  <!-- JURY CRITERIA -->
  <section class="section criteria-section" id="jury-criteria">
    <div class="container container--narrow">
      <div class="section-header">
        <span class="section-eyebrow">Standards</span>
        <h2>Jury Selection Criteria</h2>
        <hr class="divider divider--center" />
      </div>

      <p class="criteria-intro">
        The jury is formed by invitation only, based on the professional achievements and recognized
        expertise of candidates. The jury composition is confirmed by official order prior to the
        competition date.
      </p>

      <div class="criteria-list">
        <div class="criteria-item">
          <div class="criteria-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <p>Confirmed professional experience in the field of visual arts, cinematography, photography, digital art, or related disciplines</p>
        </div>
        <div class="criteria-item">
          <div class="criteria-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <p>Membership in professional creative associations, unions of artists, or other recognized arts organizations</p>
        </div>
        <div class="criteria-item">
          <div class="criteria-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <p>Original works, exhibition history, awards, or other documented professional achievements</p>
        </div>
        <div class="criteria-item">
          <div class="criteria-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          <p>Recognition by the professional community in the relevant field</p>
        </div>
      </div>

      <p class="criteria-note">
        Jury membership is not open to general applications. Jury members are selected by the
        competition organizer on the basis of their professional standing and appointed by official order.
      </p>

      <div class="text-center mt-4">
        <a href="/jury" class="btn btn--primary">View Jury Panel</a>
      </div>
    </div>
  </section>

  <!-- JSON-LD Event -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "International Visual Arts Competition named after Artist Renat Elubaev 2026",
    "startDate": "2026-03-09",
    "endDate": "2026-03-20",
    "eventStatus": "https://schema.org/EventScheduled",
    "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
    "location": {
      "@type": "VirtualLocation",
      "url": "https://renatelubaev.kz/competition"
    },
    "organizer": {
      "@type": "Person",
      "name": "Renat Elubaev",
      "url": "https://renatelubaev.kz"
    },
    "description": "International Visual Arts Competition supporting contemporary visual art among young and emerging artists in Kazakhstan and the CIS region."
  })} />
</BaseLayout>

<style>
  /* ===== PAGE HEADER ===== */
  .page-header {
    padding: var(--section-spacing-sm) 0;
    text-align: center;
    background: linear-gradient(to bottom, var(--color-accent-light), var(--color-bg));
  }

  .page-header__eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .page-header__title {
    margin-bottom: 0.5rem;
  }

  .page-header__subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .page-header__badge {
    margin-top: 0.5rem;
  }

  /* ===== SECTION EYEBROW ===== */
  .section-eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  /* ===== COMP INTRO ===== */
  .comp-intro {
    font-size: 1.1rem;
    line-height: 1.9;
    text-align: center;
    color: var(--color-text-secondary);
  }

  /* ===== RESULTS STATS ===== */
  .results-stats {
    display: flex;
    justify-content: center;
    gap: 4rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .result-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .result-stat__number {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .result-stat__label {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  /* ===== NOMINATIONS ===== */
  .nominations {
    margin-bottom: 3rem;
  }

  .nominations__title {
    text-align: center;
    margin-bottom: 1.5rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .nominations__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .nomination-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--border-radius-lg);
    padding: 2rem 1.5rem;
    text-align: center;
    transition: all var(--transition-base);
  }

  .nomination-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .nomination-card__icon {
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .nomination-card__name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
  }

  /* ===== TIMELINE ===== */
  .timeline {
    max-width: 500px;
    margin: 0 auto 3rem;
  }

  .timeline__title {
    text-align: center;
    margin-bottom: 2rem;
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .timeline__items {
    position: relative;
    padding-left: 2rem;
  }

  .timeline__items::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--color-border);
  }

  .timeline__item {
    position: relative;
    padding-bottom: 2rem;
  }

  .timeline__item:last-child {
    padding-bottom: 0;
  }

  .timeline__marker {
    position: absolute;
    left: -2rem;
    top: 4px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-border);
    border: 3px solid var(--color-bg);
  }

  .timeline__item--completed .timeline__marker {
    background: var(--color-accent);
  }

  .timeline__content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .timeline__date {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .timeline__label {
    font-size: 0.88rem;
    color: var(--color-text-muted);
  }

  .results-note {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .results-note p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    font-style: italic;
  }

  /* ===== CRITERIA ===== */
  .criteria-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border-light);
  }

  .criteria-intro {
    text-align: center;
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .criteria-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .criteria-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-bg);
    border-radius: var(--border-radius);
    border: 1px solid var(--color-border-light);
  }

  .criteria-item__icon {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .criteria-item p {
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .criteria-note {
    text-align: center;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.7;
  }

  /* ===== RESULTS SECTION ===== */
  .results-section {
    border-bottom: 1px solid var(--color-border-light);
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    .results-stats {
      gap: 2rem;
    }

    .nominations__grid {
      grid-template-columns: 1fr 1fr;
    }

    .result-stat__number {
      font-size: 2.2rem;
    }
  }

  @media (max-width: 480px) {
    .nominations__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
